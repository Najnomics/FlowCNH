# Conflux eSpace
CONFLUX_ESPACE_RPC=https://evm.confluxrpc.com
CONFLUX_ESPACE_TESTNET_RPC=https://evmtestnet.confluxrpc.com
CHAIN_ID=71

# Deployer
PRIVATE_KEY=your_private_key_here

# Protocol addresses (eSpace testnet — update after deployment)
AXCNH_ADDRESS=0x0000000000000000000000000000000000000000
USDT0_ADDRESS=0x0000000000000000000000000000000000000000
DFORCE_UNITUS_COMPTROLLER=0x0000000000000000000000000000000000000000
DFORCE_ITOKEN_AXCNH=0x0000000000000000000000000000000000000000
MESON_ROUTER=0x0000000000000000000000000000000000000000
KINETFLOW_ROUTER=0x0000000000000000000000000000000000000000

# Conflux built-in (same on all networks)
SPONSOR_WHITELIST_CONTROL=0x0888000000000000000000000000000000000001

# Sponsor funding
SPONSOR_FUND_AMOUNT_CFX=500

# Yield harvester
HARVEST_INTERVAL_SECONDS=3600
PROTOCOL_FEE_BPS=2000

# Stream settings
DISPUTE_WINDOW_SECONDS=86400

# Frontend
NEXT_PUBLIC_CHAIN_ID=71
